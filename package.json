{
    "name": "homebridge-vantage-infusion-controller",
    "displayName": "Vantage InFusion Controller",
    "version": "1.0.0",
    "description": "Homebridge plugin for Vantage Controls InFusion systems. Supports unlimited devices, all accessory types (lights, dimmers, fans with speed, switches, outlets, thermostats), and auto-reconnect.",
    "main": "dist/homebridge-vantage-static.js",
    "scripts": {
        "clean": "rimraf ./dist",
        "build": "rimraf ./dist && tsc",
        "prepublishOnly": "npm run build",
        "postpublish": "npm run clean"
    },
    "author": "richard pack",
    "contributors": [
        "Marco Arz"
    ],
    "engines": {
        "homebridge": ">=1.0.0",
        "node": ">=12.0.0"
    },
    "keywords": [
        "homebridge-plugin",
        "vantage",
        "infusion",
        "homekit",
        "smart-home"
    ],
    "license": "MIT",
    "files": [
        "dist"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/Marcoarz/homebridge-vantage.git"
    },
    "devDependencies": {
        "@types/node": "^16.0.0",
        "homebridge": "^1.0.4",
        "rimraf": "^3.0.2",
        "typescript": "^4.2.4"
    },
    "dependencies": {
        "fast-xml-parser": "^4.5.0"
    }
}
